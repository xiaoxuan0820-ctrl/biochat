{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/renderer/src/assets/**/*",
    "src/renderer/browser/env.d.ts",
    "src/renderer/browser/**/*",
    "src/renderer/browser/**/*.vue",
    "src/renderer/browser/assets/**/*",
    "src/renderer/floating/env.d.ts",
    "src/renderer/floating/**/*",
    "src/renderer/floating/**/*.vue",
    "src/renderer/floating/assets/**/*",
    "src/renderer/splash/**/*",
    "src/renderer/splash/**/*.vue",
    "src/renderer/splash/assets/**/*",
    "src/preload/*.d.ts",
    "src/renderer/api/**/*",
    "src/shared/**/*",
    "src/shadcn/**/*",
    "src/renderer/settings/**/*",
    "src/renderer/settings/**/*.vue"
  ],
  "compilerOptions": {
    "module": "esnext",
    "composite": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/renderer/src/*"
      ],
      "@api/*": [
        "./src/renderer/api/*"
      ],
      "@browser/*": [
        "./src/renderer/browser/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@shadcn/*": [
        "./src/shadcn/*"
      ]
    }
  }
}
